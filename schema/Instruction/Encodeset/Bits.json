    "type": "object",
    "info": [
        [
            "A `Bits` object represents a group of one or more bits in an `Encodeset`. The `range`",
            "property states how many bits are present and where they are in the `Encodeset`."
        ]
    ],
    "examples": [
        {
            "_type": "Instruction.Encodeset.Bits",
            "range": {
                "_type": "Range",
                "start": 3,
                "width": 2
            },
            "value": {
                "_type": "Values.Value",
                "value": "'10'",
                "meaning": null
            },
            "should_be_mask": {
                "_type": "Values.Value",
                "value": "'00'"
            }
        },
        {
            "_type": "Instruction.Encodeset.Bits",
            "range": {
                "_type": "Range",
                "start": 0,
                "width": 4
            },
            "value": {
                "_type": "Values.Value",
                "value": "'1100'",
                "meaning": null
            },
            "should_be_mask": {
                "_type": "Values.Value",
                "value": "'0000'"
            }
        }
    ],
