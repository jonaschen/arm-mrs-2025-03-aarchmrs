    "info": [
        "A model representing a slice of a value, used in SquareOp:",
        "For example: `31:16`",
        "Unless otherwise stated, all slices refer to bits and bit addresses."
    ],
    "examples": [
        {
            "_type": "AST.Slice",
            "left": {
                "_type": "AST.Integer",
                "value": 31
            },
            "right": {
                "_type": "AST.Integer",
                "value": 16
            }
        }
    ],
    "properties": {
