                "The condition under which the current access applies. This is effectively the `if` statement in the rendered pseudocode."
            ],
            "$ref": "../../Traits/HasCondition.json#/definitions/condition"
        }
    },
    "required": [
        "access"
    ],
    "title": "SystemAccess",
